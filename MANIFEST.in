# MANIFEST.in - Файлы для включения в исходный дистрибутив
# Создаётся для корректной сборки пакета (pip install / python setup.py sdist)

# Документация
include README.md
include CHANGELOG.md
include DOCUMENTATION_RU.md
include LICENSE

# Конфигурационные файлы
include translations.json
include gui_config.json
include filters_config.json
include requirements.txt

# Рекурсивно включаем все JSON из подпакетов
recursive-include gui *.json
recursive-include config *.json
recursive-include language *.json
recursive-include helpers *.json

# Базы данных (если есть)
include translations.db

# Исключаем временные файлы и кэш
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.egg-info
global-exclude .git
global-exclude .github
global-exclude .gitignore
global-exclude .cursorrules
global-exclude .assistant_audit_state.md
